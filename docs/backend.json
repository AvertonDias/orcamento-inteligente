
{
  "entities": {
    "ContaFinanceira": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContaFinanceira",
      "type": "object",
      "description": "Representa uma conta financeira (bancária ou de cartão de crédito).",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "tipo": { "type": "string" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "tipo", "dataCriacao"]
    },
    "Categoria": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Categoria",
      "type": "object",
      "description": "Representa uma categoria definida pelo usuário.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "tipoPadrao": { "type": "string" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "tipoPadrao", "dataCriacao"]
    },
    "Transacao": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transacao",
      "type": "object",
      "description": "Representa uma única movimentação financeira.",
      "properties": {
        "id": { "type": "string" },
        "descricao": { "type": "string" },
        "valor": { "type": "number" },
        "data": { "type": "string", "format": "date" },
        "tipo": { "type": "string" },
        "category": { "type": "string" },
        "bank": { "type": "string", "enum": ["bb", "nubank", "manual"] },
        "isIgnored": { "type": "boolean" },
        "observations": { "type": "string" }
      },
      "required": ["id", "descricao", "valor", "data", "tipo"]
    },
    "MonthlyAdjustment": {
      "title": "MonthlyAdjustment",
      "type": "object",
      "description": "Tabelas de ajustes personalizados por mês (ex: divisões de cartão).",
      "properties": {
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "baseValue": { "type": "number" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "value": { "type": "number" },
                    "type": { "type": "string", "enum": ["plus", "minus"] }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/contasFinanceiras/{contaFinanceiraId}",
        "definition": {
          "entityName": "ContaFinanceira",
          "schema": { "$ref": "#/backend/entities/ContaFinanceira" },
          "description": "Contas financeiras do usuário."
        }
      },
      {
        "path": "/users/{userId}/categorias/{categoriaId}",
        "definition": {
          "entityName": "Categoria",
          "schema": { "$ref": "#/backend/entities/Categoria" },
          "description": "Categorias personalizadas."
        }
      },
      {
        "path": "/users/{userId}/transactions/{transacaoId}",
        "definition": {
          "entityName": "Transacao",
          "schema": { "$ref": "#/backend/entities/Transacao" },
          "description": "Transações financeiras."
        }
      },
      {
        "path": "/users/{userId}/adjustments/{monthId}",
        "definition": {
          "entityName": "MonthlyAdjustment",
          "schema": { "$ref": "#/backend/entities/MonthlyAdjustment" },
          "description": "Ajustes e calculadoras personalizadas por mês."
        }
      },
      {
        "path": "/users/{userId}/settings/{settingId}",
        "definition": {
          "entityName": "UserSettings",
          "schema": {
            "type": "object",
            "properties": {
              "categories": { "type": "array", "items": { "type": "string" } },
              "ignoredDescriptions": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": "Configurações do usuário."
        }
      }
    ]
  }
}
