{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Um registro de transação financeira.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["receita", "despesa"] },
        "userId": { "type": "string" },
        "isIgnored": { "type": "boolean", "description": "Define se a transação deve ser ignorada nos cálculos." }
      },
      "required": ["date", "description", "amount", "category", "type", "userId"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "Configurações personalizadas do usuário.",
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/backend/entities/Transaction" },
      "description": "Transações financeiras do usuário"
    },
    "/users/{userId}/settings/config": {
      "schema": { "$ref": "#/backend/entities/UserSettings" },
      "description": "Configurações globais do usuário"
    }
  }
}